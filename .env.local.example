# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Booking page backend (Apps Script web app, runs as hello@thestepsfoundation.com).
# Server-side only — do NOT prefix with NEXT_PUBLIC_ (must never reach the browser).
BOOKING_API_URL=https://script.google.com/macros/s/XXXX/exec
BOOKING_API_TOKEN=your-shared-secret
